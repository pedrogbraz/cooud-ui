{
  "name": "cooud-ui",
  "private": true,
  "version": "0.3.0",
  "description": "Cooud Design System — themeable shadcn-class component library (Aurora + Neutral).",
  "license": "MIT",
  "packageManager": "bun@1.3.14",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "typecheck": "turbo run typecheck",
    "lint": "biome check .",
    "format": "biome format --write .",
    "www": "turbo run dev --filter=@cooud-ui/www",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "registry:check": "bun run -F cooud-ui registry:check",
    "tokens:check": "bun run -F @cooud-ui/tokens tokens:check",
    "props:check": "bun run -F @cooud-ui/www props:check",
    "package:smoke": "node scripts/package-smoke.mjs",
    "release": "node scripts/release.mjs",
    "bundle:check": "node scripts/bundle-check.mjs",
    "check:example-sections": "node scripts/check-example-sections.mjs",
    "a11y:routes": "node scripts/build-a11y-routes.mjs",
    "a11y:routes:check": "node scripts/build-a11y-routes.mjs --check",
    "audit": "bun audit",
    "test:a11y": "playwright test --project=a11y --workers=4",
    "test:contrast": "playwright test e2e/a11y/contrast-themes.spec.ts --project=a11y --workers=4",
    "test:e2e": "playwright test --project=e2e"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@biomejs/biome": "^2.0.6",
    "@playwright/test": "^1.61.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@vitest/coverage-v8": "^4.1.9",
    "jsdom": "^29.1.1",
    "turbo": "^2.3.3",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9",
    "vitest-axe": "^0.1.0"
  },
  "overrides": {
    "esbuild": "^0.28.1",
    "postcss": ">=8.5.10",
    "zod": "^4.4.3"
  },
  "engines": {
    "node": ">=20"
  }
}
