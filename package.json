{
  "name": "cooud-ui",
  "private": true,
  "version": "0.1.0",
  "description": "Cooud Design System — themeable shadcn-class component library (Aurora + Neutral).",
  "license": "MIT",
  "packageManager": "bun@1.3.14",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "typecheck": "turbo run typecheck",
    "lint": "biome check .",
    "format": "biome format --write .",
    "www": "turbo run dev --filter=@cooud/www",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "registry:check": "bun run -F cooud-ui registry:check",
    "tokens:check": "bun run -F @cooud/tokens tokens:check",
    "package:smoke": "node scripts/package-smoke.mjs",
    "bundle:check": "node scripts/bundle-check.mjs",
    "check:example-sections": "node scripts/check-example-sections.mjs",
    "audit": "bun audit",
    "test:a11y": "playwright test --project=a11y",
    "test:e2e": "playwright test --project=e2e"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@biomejs/biome": "^2.0.6",
    "@playwright/test": "^1.61.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@vitest/coverage-v8": "^4.1.9",
    "jsdom": "^29.1.1",
    "turbo": "^2.3.3",
    "typescript": "^5.9.3",
    "vitest": "^4.1.9",
    "vitest-axe": "^0.1.0"
  },
  "overrides": {
    "esbuild": "^0.28.1",
    "postcss": ">=8.5.10"
  },
  "engines": {
    "node": ">=20"
  }
}
