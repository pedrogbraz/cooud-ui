{
  "name": "cooud-ui",
  "version": "0.5.0",
  "description": "cooud-ui — add Cooud UI components to your project, shadcn-style (copy-paste registry).",
  "type": "module",
  "license": "MIT",
  "author": "Cooud",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pedrogbraz/cooud-ui.git",
    "directory": "packages/cli"
  },
  "homepage": "https://github.com/pedrogbraz/cooud-ui#readme",
  "bugs": {
    "url": "https://github.com/pedrogbraz/cooud-ui/issues"
  },
  "keywords": [
    "cooud",
    "components",
    "design-system",
    "registry",
    "shadcn",
    "tailwind",
    "ui"
  ],
  "bin": {
    "cooud-ui": "./dist/index.js"
  },
  "files": [
    "dist",
    "templates",
    "LICENSE",
    "README.md",
    "!dist/**/*.map"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./compose": {
      "types": "./dist/compose.d.ts",
      "import": "./dist/compose.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "prepublishOnly": "tsc -p tsconfig.json",
    "registry": "bun run scripts/build-registry.ts",
    "registry:check": "bun run scripts/check-registry.ts"
  },
  "dependencies": {
    "@cooud-ui/ai-kit": "workspace:*",
    "commander": "^15.0.0",
    "picocolors": "^1.1.1"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "typescript": "^6.0.3"
  },
  "engines": {
    "node": ">=22.12.0"
  }
}
