{
  "name": "@cooud-ui/theme",
  "version": "0.3.0",
  "description": "Cooud runtime theming engine — CooudUIProvider + useTheme (CSS-var only, no re-render).",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "license": "MIT",
  "author": "Cooud",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pedrogbraz/cooud-ui.git",
    "directory": "packages/theme"
  },
  "homepage": "https://github.com/pedrogbraz/cooud-ui#readme",
  "bugs": {
    "url": "https://github.com/pedrogbraz/cooud-ui/issues"
  },
  "keywords": [
    "cooud",
    "design-system",
    "react",
    "tailwind",
    "ui",
    "components"
  ],
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md",
    "!dist/**/*.map"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "prepublishOnly": "tsc -p tsconfig.json"
  },
  "dependencies": {
    "@cooud-ui/tokens": "workspace:*"
  },
  "peerDependencies": {
    "react": "^18.3.0 || ^19.0.0",
    "react-dom": "^18.3.0 || ^19.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  }
}
