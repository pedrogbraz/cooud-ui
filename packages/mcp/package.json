{
  "name": "cooud-ui-mcp",
  "version": "0.3.0",
  "description": "Model Context Protocol server for Cooud UI — lets MCP-compatible AI agents discover and fetch Cooud UI components and blocks from the registry.",
  "type": "module",
  "license": "MIT",
  "author": "Cooud",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pedrogbraz/cooud-ui.git",
    "directory": "packages/mcp"
  },
  "homepage": "https://github.com/pedrogbraz/cooud-ui#readme",
  "bugs": {
    "url": "https://github.com/pedrogbraz/cooud-ui/issues"
  },
  "keywords": [
    "cooud",
    "components",
    "design-system",
    "registry",
    "mcp",
    "model-context-protocol",
    "shadcn",
    "tailwind",
    "ui"
  ],
  "bin": {
    "cooud-ui-mcp": "./dist/index.js"
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md",
    "!dist/**/*.map"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
