{
  "name": "create-cooud-app",
  "version": "0.1.0",
  "description": "Scaffold a Next.js + Cooud UI app in one command: npx create-cooud-app my-app.",
  "type": "module",
  "license": "MIT",
  "author": "Cooud",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pedrogbraz/cooud-ui.git",
    "directory": "packages/create-cooud-app"
  },
  "homepage": "https://github.com/pedrogbraz/cooud-ui#readme",
  "bugs": {
    "url": "https://github.com/pedrogbraz/cooud-ui/issues"
  },
  "keywords": [
    "cooud",
    "create-cooud-app",
    "design-system",
    "next",
    "scaffold",
    "starter",
    "tailwind",
    "ui"
  ],
  "bin": {
    "create-cooud-app": "./dist/index.js"
  },
  "files": [
    "dist",
    "templates",
    "LICENSE",
    "README.md",
    "!dist/**/*.map"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "prepublishOnly": "tsc -p tsconfig.json"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "typescript": "^6.0.3"
  },
  "engines": {
    "node": ">=20"
  }
}
