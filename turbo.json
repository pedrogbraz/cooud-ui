{
  "$schema": "https://turbo.build/schema.json",
  "ui": "stream",
  "globalPassThroughEnv": [
    "BUNDLE_BUDGET_SLACK",
    "BUNDLE_STATS_FILE",
    "BUNDLE_UI_DIST_DIR",
    "BUNDLE_CHECK_STRICT",
    "PLAYWRIGHT_PORT"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", ".next/**", "!.next/cache/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "typecheck": {
      "dependsOn": ["^build"]
    },
    "lint": {}
  }
}
